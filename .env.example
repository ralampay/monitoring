PROMETHEUS_PORT=9999
PROMETHEUS_CONFIG_FILE=./prometheus/prometheus.dev.yml
PROMETHEUS_RETENTION_TIME=30d
PROMETHEUS_APP_KEY=replace-with-runbunny-metrics-token

GRAFANA_PORT=8888
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-now
GRAFANA_COOKIE_SECURE=false
GRAFANA_ROOT_URL=http://localhost:8888
GRAFANA_DOMAIN=localhost
