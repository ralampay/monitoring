GRAFANA_PORT=8888
PROMETHEUS_PORT=9999

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme

# Set to true when Grafana is served over HTTPS behind a reverse proxy.
GRAFANA_COOKIE_SECURE=false

# Update these when serving Grafana on a real hostname.
GRAFANA_ROOT_URL=http://localhost:8888
GRAFANA_DOMAIN=localhost

# Prometheus retention for local TSDB data.
PROMETHEUS_RETENTION_TIME=30d
